<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingHorizontal="@dimen/screen_horizontal_margin"
        android:paddingTop="@dimen/screen_vertical_gap"
        android:paddingBottom="@dimen/screen_vertical_gap"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/_4sdp">

                <ImageView
                    android:id="@+id/backButton"
                    android:layout_width="@dimen/_24sdp"
                    android:layout_height="@dimen/_24sdp"
                    android:contentDescription="@string/generated_back"
                    android:padding="@dimen/_4sdp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/black" />

                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/_6sdp"
                    android:fontFamily="@font/satoshi_bold"
                    android:text="@string/generated_catalogue_title"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_20ssp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/downloadAllButton"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/_40sdp"
                    android:fontFamily="@font/satoshi_bold"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/download_all"
                    android:textAllCaps="false"
                    android:textSize="@dimen/_14ssp"
                    app:backgroundTint="@color/textPrimary"
                    app:cornerRadius="@dimen/input_corner_radius"
                    app:icon="@drawable/ic_gallery"
                    app:iconGravity="textStart"
                    app:iconPadding="@dimen/_8sdp"
                    app:iconTint="@color/white" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_8sdp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/surface_card_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/strokeLight"
                app:strokeWidth="@dimen/_1sdp">

                <FrameLayout
                    android:id="@+id/previewContainer"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/generated_preview_height"
                    android:padding="@dimen/_8sdp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="@dimen/generated_preview_corner_radius"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/mainPreviewImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:adjustViewBounds="true"
                            android:scaleType="fitXY" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/previousButton"
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_gravity="center_vertical|start"
                        android:layout_marginStart="@dimen/_12sdp"
                        app:cardBackgroundColor="#66FFFFFF"
                        app:cardCornerRadius="@dimen/_10sdp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="@dimen/_20sdp"
                            android:layout_height="@dimen/_20sdp"
                            android:layout_gravity="center"
                            android:rotation="90"
                            android:src="@drawable/ic_arrow_drop_down"
                            app:tint="@color/white" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/nextButton"
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="@dimen/_12sdp"
                        app:cardBackgroundColor="#66FFFFFF"
                        app:cardCornerRadius="@dimen/_10sdp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="@dimen/_20sdp"
                            android:layout_height="@dimen/_20sdp"
                            android:layout_gravity="center"
                            android:rotation="-90"
                            android:src="@drawable/ic_arrow_drop_down"
                            app:tint="@color/white" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_margin="@dimen/_10sdp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/imageCountChip"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/_40sdp"
                            app:cardBackgroundColor="#33FFFFFF"
                            app:cardCornerRadius="@dimen/_10sdp"
                            app:cardElevation="0dp">

                            <TextView
                                android:id="@+id/imageCountText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="@dimen/_12sdp"
                                android:paddingVertical="@dimen/_10sdp"
                                android:text="@string/generated_front_view"
                                android:textColor="@color/white"
                                android:textSize="@dimen/_14ssp"
                                android:textStyle="bold" />

                        </com.google.android.material.card.MaterialCardView>

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

<!--                        <com.google.android.material.card.MaterialCardView-->
<!--                            android:id="@+id/expandButton"-->
<!--                            android:layout_width="@dimen/_40sdp"-->
<!--                            android:layout_height="@dimen/_40sdp"-->
<!--                            android:layout_marginEnd="@dimen/_8sdp"-->
<!--                            app:cardBackgroundColor="#CCFFFFFF"-->
<!--                            app:cardCornerRadius="@dimen/_10sdp"-->
<!--                            app:cardElevation="0dp">-->

                            <ImageView
                                android:id="@+id/expandButton"
                                android:layout_width="@dimen/_40sdp"
                                android:layout_height="@dimen/_40sdp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_expandd"
                                app:tint="@color/white" />
<!--                        </com.google.android.material.card.MaterialCardView>-->

<!--                        <com.google.android.material.card.MaterialCardView-->
<!--                            android:id="@+id/downloadOneButton"-->
<!--                            android:layout_width="@dimen/_40sdp"-->
<!--                            android:layout_height="@dimen/_40sdp"-->
<!--                            app:cardBackgroundColor="#CCFFFFFF"-->
<!--                            app:cardCornerRadius="@dimen/_10sdp"-->
<!--                            app:cardElevation="0dp">-->

                            <ImageView
                                android:id="@+id/downloadOneButton"
                                android:layout_width="@dimen/_40sdp"
                                android:layout_height="@dimen/_40sdp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_downloadd"
                                android:layout_marginStart="@dimen/_10sdp"
                                app:tint="@color/white" />
<!--                        </com.google.android.material.card.MaterialCardView>-->
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/thumbnailRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_120sdp"
                android:layout_marginTop="@dimen/_10sdp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                tools:itemCount="3"
                tools:listitem="@layout/item_thumbnail" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <FrameLayout
        android:id="@+id/generationProgressOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/screenBackground"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginHorizontal="@dimen/screen_horizontal_margin"
            android:background="@drawable/bg_generation_progress_panel"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/_20sdp"
            android:paddingVertical="@dimen/_24sdp">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_width="@dimen/_60sdp"
                android:layout_height="@dimen/_60sdp"
                android:layout_gravity="center_horizontal"
                android:indeterminate="true"
                app:indicatorColor="@color/primaryColor"
                app:indicatorSize="@dimen/_60sdp"
                app:trackColor="@color/primaryContainer"
                app:trackThickness="@dimen/_5sdp" />

            <TextView
                android:id="@+id/generationProgressMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_18sdp"
                android:fontFamily="@font/satoshi_bold"
                android:gravity="center"
                android:text="@string/generating_images"
                android:textColor="@color/black"
                android:textSize="@dimen/_18ssp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_6sdp"
                android:fontFamily="@font/satoshi_medium"
                android:gravity="center"
                android:text="@string/generated_progress_hint"
                android:textColor="@color/textSecondary"
                android:textSize="@dimen/_12ssp" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/generationProgressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_20sdp"
                android:max="100"
                android:progress="0"
                app:indicatorColor="@color/primaryColor"
                app:trackColor="@color/primaryContainer"
                app:trackCornerRadius="@dimen/_4sdp"
                app:trackThickness="@dimen/_8sdp" />

            <TextView
                android:id="@+id/generationProgressPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/_8sdp"
                android:fontFamily="@font/satoshi_bold"
                android:text="0%"
                android:textColor="@color/textSecondary"
                android:textSize="@dimen/_14ssp" />
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
