<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_white_rounded"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/_20sdp"
    android:paddingTop="@dimen/_18sdp"
    android:paddingBottom="@dimen/_24sdp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/satoshi_bold"
        android:text="@string/update_password_title"
        android:textColor="@color/textPrimary"
        android:textSize="@dimen/_18ssp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_4sdp"
        android:fontFamily="@font/satoshi_medium"
        android:text="@string/update_password_subtitle"
        android:textColor="@color/ash"
        android:textSize="@dimen/_13ssp" />

    <EditText
        android:id="@+id/currentPasswordEt"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_48sdp"
        android:layout_marginTop="@dimen/_18sdp"
        android:background="@drawable/et_bg"
        android:fontFamily="@font/satoshi_medium"
        android:hint="@string/update_password_current"
        android:inputType="textPassword"
        android:paddingHorizontal="@dimen/_12sdp"
        android:textColor="@color/ash"
        android:textSize="@dimen/_14ssp" />

    <EditText
        android:id="@+id/newPasswordEt"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_48sdp"
        android:layout_marginTop="@dimen/_12sdp"
        android:background="@drawable/et_bg"
        android:fontFamily="@font/satoshi_medium"
        android:hint="@string/update_password_new"
        android:inputType="textPassword"
        android:paddingHorizontal="@dimen/_12sdp"
        android:textColor="@color/ash"
        android:textSize="@dimen/_14ssp" />

    <EditText
        android:id="@+id/confirmPasswordEt"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_48sdp"
        android:layout_marginTop="@dimen/_12sdp"
        android:background="@drawable/et_bg"
        android:fontFamily="@font/satoshi_medium"
        android:hint="@string/update_password_confirm"
        android:inputType="textPassword"
        android:paddingHorizontal="@dimen/_12sdp"
        android:textColor="@color/ash"
        android:textSize="@dimen/_14ssp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/updatePasswordButton"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_48sdp"
        android:layout_marginTop="@dimen/_18sdp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="@string/update_password_button"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="@dimen/_14ssp"
        app:backgroundTint="@color/primaryColor"
        app:cornerRadius="@dimen/input_corner_radius" />
</LinearLayout>
