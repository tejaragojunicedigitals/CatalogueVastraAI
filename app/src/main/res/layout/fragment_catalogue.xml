<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.fragments.CatalogueFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingHorizontal="@dimen/screen_horizontal_margin"
        android:paddingTop="@dimen/_16sdp"
        android:paddingBottom="@dimen/_96sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/headerContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/satoshi_bold"
                    android:text="@string/catalogues_title"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_24ssp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_4sdp"
                    android:fontFamily="@font/satoshi_medium"
                    android:text="@string/view_manage_and_download_your_previously_generated_catalogues_images"
                    android:textColor="@color/ash"
                    android:textSize="@dimen/_14ssp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/searchCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_20sdp"
                android:layout_marginEnd="@dimen/_8sdp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/input_corner_radius"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toStartOf="@id/filterMenuButton"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerContent"
                app:strokeColor="@color/grey"
                app:strokeWidth="@dimen/_1sdp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/_14sdp"
                    android:paddingVertical="@dimen/_4sdp">

                    <ImageView
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="@dimen/_20sdp"
                        android:contentDescription="@string/catalogues_search_hint"
                        android:src="@drawable/ic_search_catalogue"
                        app:tint="@color/ash" />

                    <EditText
                        android:id="@+id/searchInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_8sdp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:fontFamily="@font/satoshi_medium"
                        android:hint="@string/catalogues_search_hint"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"
                        android:paddingVertical="@dimen/_8sdp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/ash"
                        android:textSize="@dimen/_14ssp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/filterMenuButton"
                android:layout_width="@dimen/_45sdp"
                android:layout_height="@dimen/_45sdp"
                android:contentDescription="@string/catalogues_filter_menu"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@color/white"
                app:cornerRadius="@dimen/input_corner_radius"
                app:icon="@drawable/ic_menu_lines"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@color/bottomNavInactive"
                app:layout_constraintBottom_toBottomOf="@id/searchCard"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/searchCard"
                app:strokeColor="@color/grey"
                app:strokeWidth="@dimen/_1sdp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/filterPanel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/_18sdp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/searchCard"
                app:strokeColor="@color/grey"
                app:strokeWidth="@dimen/_1sdp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/_10sdp">

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:overScrollMode="never"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/dateFilterButton"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="@dimen/_40sdp"
                                android:layout_marginEnd="@dimen/_8sdp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minWidth="@dimen/_100sdp"
                                android:text="@string/catalogues_filter_date"
                                android:textAllCaps="false"
                                android:textColor="@color/bottomNavInactive"
                                android:textSize="@dimen/_14ssp"
                                app:backgroundTint="@color/white"
                                app:cornerRadius="@dimen/input_corner_radius"
                                app:icon="@drawable/ic_arrow_drop_down"
                                app:iconGravity="textEnd"
                                app:iconPadding="@dimen/_10sdp"
                                app:iconTint="@color/bottomNavInactive"
                                app:strokeColor="@color/grey"
                                app:strokeWidth="@dimen/_1sdp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/categoryFilterButton"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="@dimen/_40sdp"
                                android:layout_marginEnd="@dimen/_8sdp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minWidth="@dimen/_120sdp"
                                android:text="@string/catalogues_filter_category"
                                android:textAllCaps="false"
                                android:textColor="@color/bottomNavInactive"
                                android:textSize="@dimen/_14ssp"
                                app:backgroundTint="@color/white"
                                app:cornerRadius="@dimen/input_corner_radius"
                                app:icon="@drawable/ic_arrow_drop_down"
                                app:iconGravity="textEnd"
                                app:iconPadding="@dimen/_10sdp"
                                app:iconTint="@color/bottomNavInactive"
                                app:strokeColor="@color/grey"
                                app:strokeWidth="@dimen/_1sdp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/platformFilterButton"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="@dimen/_40sdp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minWidth="@dimen/_120sdp"
                                android:text="@string/catalogues_filter_platform"
                                android:textAllCaps="false"
                                android:textColor="@color/bottomNavInactive"
                                android:textSize="@dimen/_14ssp"
                                app:backgroundTint="@color/white"
                                app:cornerRadius="@dimen/input_corner_radius"
                                app:icon="@drawable/ic_arrow_drop_down"
                                app:iconGravity="textEnd"
                                app:iconPadding="@dimen/_10sdp"
                                app:iconTint="@color/bottomNavInactive"
                                app:strokeColor="@color/grey"
                                app:strokeWidth="@dimen/_1sdp" />
                        </LinearLayout>
                    </HorizontalScrollView>

                    <LinearLayout
                        android:id="@+id/filterOptionsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/actionButtonsRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_12sdp"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/filterPanel">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/selectAllButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_40sdp"
                    android:layout_marginEnd="@dimen/_8sdp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:text="@string/catalogues_select_all"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_14ssp"
                    app:backgroundTint="@color/white"
                    app:cornerRadius="@dimen/input_corner_radius"
                    app:icon="@drawable/ic_catalogue_select_unchecked"
                    app:iconGravity="textStart"
                    app:iconPadding="@dimen/_8sdp"
                    app:iconTint="@null"
                    app:strokeColor="@color/grey"
                    app:strokeWidth="@dimen/_1sdp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/downloadSelectedButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_40sdp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:text="@string/download_all"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_14ssp"
                    app:backgroundTint="@color/textPrimary"
                    app:cornerRadius="@dimen/input_corner_radius"
                    app:icon="@drawable/ic_download_outline"
                    app:iconGravity="textStart"
                    app:iconPadding="@dimen/_8sdp"
                    app:iconTint="@color/white" />
            </LinearLayout>

            <TextView
                android:id="@+id/emptyStateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_16sdp"
                android:fontFamily="@font/satoshi_medium"
                android:text="@string/catalogues_empty_state"
                android:textColor="@color/ash"
                android:textSize="@dimen/_14ssp"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/actionButtonsRow" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/cataloguesRecyclerView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_12sdp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="@dimen/_8sdp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/emptyStateText"
                tools:itemCount="8"
                tools:listitem="@layout/item_catalogue_card" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/createNewButton"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/_48sdp"
        android:layout_marginEnd="@dimen/fab_margin"
        android:layout_marginBottom="@dimen/fab_margin"
        android:elevation="@dimen/_6sdp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:paddingHorizontal="@dimen/_18sdp"
        android:text="@string/catalogues_create_new"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="@dimen/_14ssp"
        app:backgroundTint="@color/primaryColor"
        app:cornerRadius="@dimen/_24sdp"
        app:icon="@drawable/ic_plus_small"
        app:iconGravity="textStart"
        app:iconPadding="@dimen/_6sdp"
        app:iconTint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
