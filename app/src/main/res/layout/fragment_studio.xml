                        android:textColor="@color/ash"
                        android:textSize="@dimen/_16ssp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/content_heading_spacing"
                        android:fontFamily="@font/satoshi_bold"
                        android:text="@string/catalogue_for_label"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_14ssp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/catalogueForInput"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_50sdp"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:background="@drawable/et_bg"
                        android:drawableEnd="@drawable/ic_arrow_drop_down"
                        android:drawablePadding="@dimen/_8sdp"
                        android:ellipsize="end"
                        android:fontFamily="@font/satoshi_regular"
                        android:gravity="center_vertical"
                        android:inputType="none"
                        android:maxLines="1"
                        android:paddingLeft="@dimen/_12sdp"
                        android:paddingTop="@dimen/_2sdp"
                        android:paddingRight="@dimen/_12sdp"
                        android:paddingBottom="@dimen/_2sdp"
                        android:textColor="@color/textPrimary"
                        android:textColorHint="@color/textSecondary"
                        android:textSize="@dimen/_12ssp"
                        app:drawableTint="@color/textSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/section_spacing"
                        android:fontFamily="@font/satoshi_bold"
                        android:text="@string/category_type_label"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_14ssp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/categoryInput"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_50sdp"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:background="@drawable/et_bg"
                        android:drawableEnd="@drawable/ic_arrow_drop_down"
                        android:drawablePadding="@dimen/_8sdp"
