                            android:fontFamily="@font/satoshi_bold"
                            android:text="@string/pose_label"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_14ssp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
