                            android:gravity="center"
                            android:text="@string/studio_rail_empty_state"
                            android:textColor="@color/ash"
                            android:textSize="@dimen/_14ssp"
                            android:visibility="gone" />
                    </FrameLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
