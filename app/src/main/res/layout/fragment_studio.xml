                        android:text="@string/platform_label"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_14ssp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/platformRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_8sdp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:paddingEnd="@dimen/_4sdp"
                        tools:itemCount="5"
                        tools:listitem="@layout/item_chip_option" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/section_spacing"
                        android:fontFamily="@font/satoshi_medium"
                        android:text="@string/aspect_ratio_label"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_14ssp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/aspectRatioRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_8sdp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:paddingEnd="@dimen/_4sdp"
                        tools:itemCount="6"
                        tools:listitem="@layout/item_chip_option" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/section_spacing"
                        android:fontFamily="@font/satoshi_bold"
                        android:text="@string/resolution_label"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_14ssp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_8sdp"
                        android:baselineAligned="false"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/satoshi_bold"
                                android:text="@string/resolution_width_short"
                                android:textColor="@color/textSecondary"
                                android:textSize="@dimen/_12ssp" />

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_6sdp"
                                app:boxBackgroundColor="@color/white"
                                app:boxCornerRadiusBottomEnd="@dimen/input_corner_radius"
                                app:boxCornerRadiusBottomStart="@dimen/input_corner_radius"
                                app:boxCornerRadiusTopEnd="@dimen/input_corner_radius"
                                app:boxCornerRadiusTopStart="@dimen/input_corner_radius"
                                app:boxStrokeColor="@color/strokeLight"
                                app:hintEnabled="false">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/resolutionWidthInput"
                                    android:layout_width="match_parent"
                                    android:layout_height="@dimen/_40sdp"
                                    android:fontFamily="@font/satoshi_regular"
                                    android:inputType="number"
                                    android:paddingVertical="@dimen/_2sdp"
                                    android:textColor="@color/textPrimary"
                                    android:textSize="@dimen/_12ssp"
                                    tools:text="2000" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="@dimen/_40sdp"
                            android:layout_height="@dimen/_40sdp"
                            android:layout_marginHorizontal="@dimen/_12sdp"
                            app:cardBackgroundColor="@color/primaryColor"
                            app:cardCornerRadius="@dimen/_12sdp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <ImageButton
                                android:id="@+id/swapResolutionButton"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:contentDescription="@string/resolution_swap"
                                android:padding="@dimen/_10sdp"
                                android:src="@drawable/ic_swap_dimensions"
                                app:tint="@color/white" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/satoshi_bold"
                                android:text="@string/resolution_height_short"
                                android:textColor="@color/textSecondary"
                                android:textSize="@dimen/_12ssp" />

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_6sdp"
                                app:boxBackgroundColor="@color/white"
                                app:boxCornerRadiusBottomEnd="@dimen/input_corner_radius"
                                app:boxCornerRadiusBottomStart="@dimen/input_corner_radius"
                                app:boxCornerRadiusTopEnd="@dimen/input_corner_radius"
                                app:boxCornerRadiusTopStart="@dimen/input_corner_radius"
                                app:boxStrokeColor="@color/strokeLight"
                                app:hintEnabled="false">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/resolutionHeightInput"
                                    android:layout_width="match_parent"
                                    android:layout_height="@dimen/_40sdp"
                                    android:fontFamily="@font/satoshi_regular"
                                    android:inputType="number"
                                    android:paddingVertical="@dimen/_2sdp"
                                    android:textColor="@color/textPrimary"
                                    android:textSize="@dimen/_12ssp"
                                    tools:text="2000" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/content_heading_spacing">

                        <TextView
                            android:id="@+id/modelHeading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/satoshi_bold"
                            android:text="@string/model_label"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_14ssp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/modelViewAll"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/satoshi_bold"
                            android:text="@string/view_all"
                            android:textColor="@color/ash"
                            android:textSize="@dimen/_14ssp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

