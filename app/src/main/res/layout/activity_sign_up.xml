<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true"
    tools:context=".ui.activities.SignUpActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/satoshi_bold"
            android:text="@string/signup_title"
            android:textColor="@color/black"
            android:textSize="28sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/satoshi_regular"
            android:text="@string/signup_subtitle"
            android:textColor="@color/ash"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="@font/satoshi_bold"
            android:text="@string/signup_profile_image_label"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/profileImageCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/et_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/profileImagePreview"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile"
                app:shapeAppearanceOverlay="@style/CircleImage" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/satoshi_bold"
                    android:text="@string/signup_profile_image_hint"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/profileImageFileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/satoshi_regular"
                    android:text="@string/signup_no_profile_image"
                    android:textColor="@color/ash"
                    android:textSize="12sp" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/profileImageButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/gradient_bg"
                android:fontFamily="@font/satoshi_bold"
                android:paddingHorizontal="16dp"
                android:text="@string/signup_upload_button"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/satoshi_bold"
            android:text="@string/signup_business_logo_label"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/businessLogoCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/et_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <ImageView
                android:id="@+id/businessLogoPreview"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@color/white"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/business_logo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/satoshi_bold"
                    android:text="@string/signup_business_logo_hint"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/businessLogoFileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/satoshi_regular"
                    android:text="@string/signup_no_business_logo"
                    android:textColor="@color/ash"
                    android:textSize="12sp" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/businessLogoButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/gradient_bg"
                android:fontFamily="@font/satoshi_bold"
                android:paddingHorizontal="16dp"
                android:text="@string/signup_upload_button"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/satoshi_bold"
            android:text="@string/signup_username_label"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/usernameInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:autofillHints="username"
            android:background="@drawable/et_bg"
            android:fontFamily="@font/satoshi_medium"
            android:hint="@string/signup_username_hint"
            android:imeOptions="actionNext"
            android:inputType="textPersonName"
            android:paddingHorizontal="14dp"
            android:textColor="@color/black"
            android:textColorHint="@color/ash"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/satoshi_bold"
            android:text="@string/signup_business_name_label"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/businessNameInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:autofillHints="organizationName"
            android:background="@drawable/et_bg"
            android:fontFamily="@font/satoshi_medium"
            android:hint="@string/signup_business_name_hint"
            android:imeOptions="actionNext"
            android:inputType="textCapWords"
            android:paddingHorizontal="14dp"
            android:textColor="@color/black"
            android:textColorHint="@color/ash"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/satoshi_bold"
            android:text="@string/signup_email_label"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/emailInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:autofillHints="emailAddress"
            android:background="@drawable/et_bg"
            android:fontFamily="@font/satoshi_medium"
            android:hint="@string/signup_email_hint"
            android:imeOptions="actionNext"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="14dp"
            android:textColor="@color/black"
            android:textColorHint="@color/ash"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/satoshi_bold"
            android:text="@string/signup_phone_label"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/phoneInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:autofillHints="phone"
            android:background="@drawable/et_bg"
            android:fontFamily="@font/satoshi_medium"
            android:hint="@string/signup_phone_hint"
            android:imeOptions="actionNext"
            android:inputType="phone"
            android:paddingHorizontal="14dp"
            android:textColor="@color/black"
            android:textColorHint="@color/ash"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/satoshi_bold"
            android:text="@string/signup_password_label"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:autofillHints="newPassword"
            android:background="@drawable/et_bg"
            android:fontFamily="@font/satoshi_medium"
            android:hint="@string/signup_password_hint"
            android:imeOptions="actionDone"
            android:inputType="textPassword"
            android:paddingHorizontal="14dp"
            android:textColor="@color/black"
            android:textColorHint="@color/ash"
            android:textSize="14sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/createAccountButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="26dp"
            android:background="@drawable/gradient_bg"
            android:fontFamily="@font/satoshi_bold"
            android:text="@string/signup_button"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/satoshi_medium"
                android:text="@string/signup_signin_prompt"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/signInCta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="4dp"
                android:fontFamily="@font/satoshi_bold"
                android:text="@string/signup_signin_cta"
                android:textColor="@color/primaryColor"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
