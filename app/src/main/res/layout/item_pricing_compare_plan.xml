<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="@dimen/_18sdp"
    app:cardElevation="0dp"
    app:strokeColor="@color/pricingPlanBorder"
    app:strokeWidth="@dimen/_1sdp">

    <LinearLayout
        android:id="@+id/planContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:minHeight="@dimen/pricing_plan_card_min_height"
        android:orientation="vertical"
        android:padding="@dimen/_16sdp">

        <TextView
            android:id="@+id/badgeView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_pricing_compare_badge"
            android:backgroundTint="@color/primaryColor"
            android:fontFamily="@font/satoshi_bold"
            android:paddingHorizontal="@dimen/_10sdp"
            android:paddingVertical="@dimen/_4sdp"
            android:textColor="@color/white"
            android:textSize="@dimen/_10ssp"
            android:visibility="gone"
            tools:text="Best Value" />

        <TextView
            android:id="@+id/titleView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_8sdp"
            android:fontFamily="@font/satoshi_bold"
            android:gravity="center"
            android:textColor="@color/textPrimary"
            android:textSize="@dimen/_18ssp"
            tools:text="Starter Pack" />

        <TextView
            android:id="@+id/subtitleView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_4sdp"
            android:fontFamily="@font/satoshi_medium"
            android:gravity="center"
            android:lineSpacingExtra="@dimen/_2sdp"
            android:textColor="@color/textSecondary"
            android:textSize="@dimen/_12ssp"
            tools:text="Individual sellers &amp; small stores" />

        <TextView
            android:id="@+id/creditsView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_14sdp"
            android:fontFamily="@font/satoshi_bold"
            android:gravity="center"
            android:textColor="@color/textPrimary"
            android:textSize="@dimen/_24ssp"
            tools:text="2,500 Credits" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/actionButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_40sdp"
            android:layout_marginTop="@dimen/_16sdp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:textAllCaps="false"
            android:textSize="@dimen/_13ssp"
            app:backgroundTint="@color/pricingButtonSurface"
            app:cornerRadius="@dimen/_12sdp"
            app:strokeColor="@color/pricingPlanBorder"
            app:strokeWidth="@dimen/_1sdp"
            tools:text="Buy @ ₹2,500" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
