<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:endColor="@color/placeholderWindowBottom"
                android:startColor="@color/placeholderWindowTop" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item
        android:left="10dp"
        android:right="10dp"
        android:top="12dp"
        android:bottom="12dp">
        <shape>
            <solid android:color="#66FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#99FFFFFF" />
        </shape>
    </item>
    <item
        android:left="32dp"
        android:right="32dp"
        android:top="12dp"
        android:bottom="12dp">
        <shape>
            <solid android:color="#44FFFFFF" />
        </shape>
    </item>
</layer-list>
